# ============================================================================
# DATAVISION AI - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
#
# COPY THIS FILE TO .env FOR LOCAL DEVELOPMENT
# DO NOT COMMIT YOUR ACTUAL .env FILE!
#
# FOR PRODUCTION (HuggingFace Spaces):
# 1. Go to Space Settings > Variables
# 2. Add each variable as a "Secret"
# ============================================================================

# ----------------------------------------------------------------------------
# ENVIRONMENT (development / production)
# ----------------------------------------------------------------------------
ENVIRONMENT=development

# ----------------------------------------------------------------------------
# AI/LLM PROVIDER (REQUIRED)
# ----------------------------------------------------------------------------
# GROQ (Primary - FREE, Fast, Reliable)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Multiple API Keys for Load Balancing (Recommended for Production)
# Add 3-5 keys to handle high traffic without rate limits
GROQ_KEY_1=gsk_backup_key_1
GROQ_KEY_2=gsk_backup_key_2
GROQ_KEY_3=gsk_backup_key_3

# Optional Fallback Providers
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# ----------------------------------------------------------------------------
# DATABASE & AUTHENTICATION (REQUIRED FOR PERSISTENCE)
# ----------------------------------------------------------------------------
# PostgreSQL Database Connection URL (e.g., Neon, Railway, Supabase Postgres)
# Example: postgresql+asyncpg://user:password@hostname:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/datavision

# JWT signing secret (KEEP SECRET - generate a random string)
JWT_SECRET=your_jwt_secret_here

# ----------------------------------------------------------------------------
# REDIS / RATE LIMITING (OPTIONAL)
# ----------------------------------------------------------------------------
# For Redis-backed rate limiting. If empty, uses in-memory.
REDIS_URL=

# ----------------------------------------------------------------------------
# CORS & SECURITY
# ----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_HOSTS=localhost,127.0.0.1

# ----------------------------------------------------------------------------
# OPTIONAL INTEGRATIONS
# ----------------------------------------------------------------------------
# Email Service (for automated reports via Resend or SMTP)
RESEND_API_KEY=
FROM_EMAIL=insights@yourdomain.com
