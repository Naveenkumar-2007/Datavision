# ============================================================================
# DATAVISION AI - PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
#
# 🚨 IMPORTANT: Set these in HuggingFace Spaces Settings > Variables
# DO NOT commit this file with actual keys!
#
# ============================================================================

# ----------------------------------------------------------------------------
# PRODUCTION ENVIRONMENT (CRITICAL)
# ----------------------------------------------------------------------------
ENVIRONMENT=production

# ----------------------------------------------------------------------------
# AI/LLM PROVIDER (REQUIRED)
# ----------------------------------------------------------------------------
# GROQ (Primary - FREE, Fast, Reliable)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Multiple API Keys for Load Balancing (Recommended for Production)
# Add 3-5 keys to handle high traffic without rate limits
GROQ_KEY_1=gsk_backup_key_1
GROQ_KEY_2=gsk_backup_key_2
GROQ_KEY_3=gsk_backup_key_3

# Optional Fallback Providers
OPENAI_API_KEY=sk-your_openai_key_here
GOOGLE_API_KEY=your_google_api_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# ----------------------------------------------------------------------------
# DATABASE & AUTHENTICATION (REQUIRED FOR PERSISTENCE)
# ----------------------------------------------------------------------------
# Supabase (FREE tier available)
# Get from: https://supabase.com > Create Project > Settings > API

# Project URL (safe to expose in frontend)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public Key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key_here

# Service Role Key (KEEP SECRET - backend only)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_service_role_key_here

# ----------------------------------------------------------------------------
# CORS & SECURITY (AUTO-CONFIGURED FOR HUGGINGFACE)
# ----------------------------------------------------------------------------
# These are automatically configured for HuggingFace Spaces
# Only change if deploying elsewhere
CORS_ORIGINS=*
ALLOWED_HOSTS=*.hf.space,huggingface.co,localhost

# ----------------------------------------------------------------------------
# OPTIONAL INTEGRATIONS
# ----------------------------------------------------------------------------
# Email Service (for automated reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Google Sheets Integration (optional)
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key

# ----------------------------------------------------------------------------
# PERFORMANCE TUNING
# ----------------------------------------------------------------------------
# Enable caching for faster responses
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# Response generation speed vs quality
FAST_MODE=false

# Max tokens per response (controls API costs)
MAX_TOKENS_NORMAL=1500
MAX_TOKENS_FAST=500

# ============================================================================
# HOW TO USE IN HUGGINGFACE SPACES:
# ============================================================================
# 1. Go to your Space Settings
# 2. Click "Variables" tab
# 3. Add each variable above (without the =value part)
# 4. Mark sensitive ones (API keys) as "Secret"
# 5. Save and restart Space
#
# Required Variables (Minimum to run):
# - GROQ_API_KEY
# - VITE_SUPABASE_URL
# - VITE_SUPABASE_ANON_KEY
# - SUPABASE_SERVICE_KEY
# - ENVIRONMENT=production
#
# Recommended for Production:
# - Add GROQ_KEY_1, GROQ_KEY_2, GROQ_KEY_3 for load balancing
# - This prevents "API limit exceeded" from showing to users
# ============================================================================

# ----------------------------------------------------------------------------
# USER EXPERIENCE (Production Best Practices)
# ----------------------------------------------------------------------------
# ✅ IMPLEMENTED: Users NEVER see "API limit exceeded" messages
# ✅ IMPLEMENTED: Automatic failover between multiple API keys
# ✅ IMPLEMENTED: Graceful degradation when limits hit
# ✅ IMPLEMENTED: Generic "Processing..." shown to users instead of errors
# ✅ IMPLEMENTED: Data persists across sessions (Supabase + localStorage)
# ✅ IMPLEMENTED: No data leakage between users
# ✅ IMPLEMENTED: Secure file uploads with validation
# ✅ IMPLEMENTED: API keys never exposed to frontend
# ----------------------------------------------------------------------------
